# ──────────────────────────────────────────────────────────────
# Root environment file used by docker-compose.yml
# Copy to .env and adjust values before running docker-compose.
# ──────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=wholesale
POSTGRES_PASSWORD=wholesale_secret
POSTGRES_DB=wholesaleos
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=4000
NODE_ENV=production
# NOTE: host is the compose service name 'db' inside the Docker network.
DATABASE_URL=postgresql://wholesale:wholesale_secret@db:5432/wholesaleos?schema=public
JWT_ACCESS_SECRET=change_me_access_secret_please
JWT_REFRESH_SECRET=change_me_refresh_secret_please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=3000
# Base URL the browser uses to reach the API (build-time for Vite).
VITE_API_URL=http://localhost:4000/api
