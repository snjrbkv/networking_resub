# Backend environment (local, non-Docker development)
NODE_ENV=development
PORT=4000

# PostgreSQL connection string.
# For local dev with a locally installed Postgres:
DATABASE_URL=postgresql://wholesale:wholesale_secret@localhost:5432/wholesaleos?schema=public

# JWT secrets — use long random strings in production.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — the frontend origin allowed to call the API.
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging level: error | warn | info | http | debug
LOG_LEVEL=debug
